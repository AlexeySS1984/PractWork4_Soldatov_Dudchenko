<Page x:Class="PractWork4_Soldatov_Dudchenko.Page3"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
      Title="Страница 3 - Функция y с графиком">
    <Grid Background="#FFF5F5F5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Вычисление функции y с графиком" 
                   FontSize="24" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="0,20,0,20"
                   Foreground="#FF2C3E50"/>

        <Border Grid.Row="1" Background="White" CornerRadius="10" 
                Margin="30" Padding="20" 
                BorderBrush="#FFE0E0E0" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="400"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Левая панель с вводом -->
                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="15"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="15"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Формула -->
                    <Border Grid.Row="0" Background="#FFF8F9FA" 
                            CornerRadius="5" Padding="15" 
                            BorderBrush="#FFE0E0E0" BorderThickness="1">
                        <StackPanel>
                            <Image Source="formula3.png" Stretch="Uniform" Height="60"
                                   ToolTip="y = x⁴ + cos(2 + x³ - b)"/>
                            <TextBlock Text="x₀ = 4.6; xₖ = 5.8; dx = 0.2; b = 1.3" 
                                     FontSize="12" Foreground="#FF7F8C8D" 
                                     TextAlignment="Center" Margin="0,10,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Параметры (только для отображения) -->
                    <Border Grid.Row="2" Background="#FFE8F5E9" 
                            CornerRadius="5" Padding="15" 
                            BorderBrush="#FF4CAF50" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Параметры функции:" 
                                     FontSize="14" FontWeight="Bold" 
                                     Margin="0,0,0,10"/>
                            <TextBlock FontSize="13">
                                <Run Text="x₀ = 4.6 (начальное значение)"/>
                            </TextBlock>
                            <TextBlock FontSize="13">
                                <Run Text="xₖ = 5.8 (конечное значение)"/>
                            </TextBlock>
                            <TextBlock FontSize="13">
                                <Run Text="dx = 0.2 (шаг)"/>
                            </TextBlock>
                            <TextBlock FontSize="13">
                                <Run Text="b = 1.3 (константа)"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- Кнопки -->
                    <StackPanel Grid.Row="3" Margin="0,15,0,0">
                        <Button Content="Вычислить" Height="45" 
                                FontSize="16" Click="Calculate_Click"
                                Background="#FF3498DB" Foreground="White"
                                BorderThickness="0" Cursor="Hand"
                                ToolTip="Нажмите для вычисления и построения графика">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#FF3498DB"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#FF2980B9"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Content="Очистить" Height="45" 
                                FontSize="16" Click="Clear_Click" Margin="0,10,0,0"
                                Background="#FF95A5A6" Foreground="White"
                                BorderThickness="0" Cursor="Hand"
                                ToolTip="Нажмите для очистки результатов">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#FF95A5A6"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#FF7F8C8D"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>

                    <!-- Результаты -->
                    <Border Grid.Row="5" Background="#FFF8F9FA" 
                            CornerRadius="5" Padding="10" 
                            BorderBrush="#FFE0E0E0" BorderThickness="1">
                        <TextBlock Text="Результаты вычислений:" 
                                 FontSize="14" FontWeight="Bold"/>
                    </Border>

                    <Border Grid.Row="7" Background="White" 
                            CornerRadius="5" Padding="5" 
                            BorderBrush="#FFE0E0E0" BorderThickness="1">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <TextBox x:Name="txtResults" 
                                   TextWrapping="Wrap" 
                                   IsReadOnly="True"
                                   BorderThickness="0"
                                   Background="Transparent"
                                   FontFamily="Consolas"
                                   FontSize="12"
                                   ToolTip="Значения x и y"/>
                        </ScrollViewer>
                    </Border>
                </Grid>

                <!-- Правая панель с графиком -->
                <Border Grid.Column="1" Background="#FFF8F9FA" 
                        CornerRadius="5" Padding="15" Margin="15,0,0,0"
                        BorderBrush="#FFE0E0E0" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="График функции" 
                                 FontSize="16" FontWeight="Bold" 
                                 HorizontalAlignment="Center" Margin="0,0,0,15"
                                 Foreground="#FF2C3E50"/>

                        <lvc:CartesianChart x:Name="Chart" Grid.Row="1" 
                                          LegendLocation="Bottom"
                                          ToolTip="График функции y = x⁴ + cos(2 + x³ - b)">
                            <lvc:CartesianChart.AxisX>
                                <lvc:Axis Title="x" FontSize="12"/>
                            </lvc:CartesianChart.AxisX>
                            <lvc:CartesianChart.AxisY>
                                <lvc:Axis Title="y" FontSize="12"/>
                            </lvc:CartesianChart.AxisY>
                        </lvc:CartesianChart>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Page>
