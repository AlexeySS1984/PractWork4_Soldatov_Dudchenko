<Window x:Class="PractWork4_Soldatov_Dudchenko.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Практическая работа 4 Солдатов Дудченко" Height="800" Width="1200"
        WindowStartupLocation="CenterScreen" Closing="Window_Closing">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Меню навигации -->
        <Menu Grid.Row="0" Background="#FF2C3E50" Foreground="White" Height="40">
            <MenuItem Header="Страница 1" Click="Page1_Click" FontSize="14" Foreground="White" Padding="15,10"/>
            <MenuItem Header="Страница 2" Click="Page2_Click" FontSize="14" Foreground="White" Padding="15,10"/>
            <MenuItem Header="Страница 3" Click="Page3_Click" FontSize="14" Foreground="White" Padding="15,10"/>
            <MenuItem Header="Выход" Click="Exit_Click" FontSize="14" Foreground="White" Padding="15,10"/>
        </Menu>

        <!-- Контейнер для страниц -->
        <Frame x:Name="MainFrame" Grid.Row="1" NavigationUIVisibility="Hidden"/>
    </Grid>
</Window>
